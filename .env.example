# Supabase Auth
# Dapatkan nilai ini dari: https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Database (Prisma)
# Dapatkan nilai ini dari: https://supabase.com/dashboard -> Project Settings -> Database -> Connection string
#
# DATABASE_URL: Transaction Pooler (port 6543) — digunakan aplikasi saat runtime
# Tambahkan ?pgbouncer=true untuk kompatibilitas PgBouncer
DATABASE_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL: Direct Connection (port 5432) — digunakan Prisma CLI untuk migrations
DIRECT_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
