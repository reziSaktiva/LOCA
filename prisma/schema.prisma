generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL dikonfigurasi di prisma.config.ts (untuk Prisma CLI)
  // Runtime menggunakan DATABASE_URL via driver adapter di shared/infrastructure/database/client.ts
}

// ---------------------------------------------------------------------------
// Customer Module
// ---------------------------------------------------------------------------

/// Profil customer — aggregate root, ID = Supabase user ID.
model CustomerProfile {
  id          String  @id // Supabase user ID
  displayName String
  phone       String
  avatarUrl   String?

  // Audit
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  addresses CustomerAddress[]

  @@map("customer_profiles")
}

/// Alamat pengiriman customer. Satu customer boleh punya banyak alamat.
/// Satu alamat dapat ditandai sebagai default.
model CustomerAddress {
  id            String  @id @default(cuid())
  customerId    String
  recipientName String
  phone         String
  street        String
  district      String
  city          String
  province      String
  postalCode    String
  isDefault     Boolean @default(false)

  // Audit
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  // Soft delete
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deleteReason String?

  customer CustomerProfile @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_addresses")
}

// ---------------------------------------------------------------------------
// Catalog Module
// ---------------------------------------------------------------------------

enum MediaOwnerType {
  PRODUCT
  VARIANT
}

enum ProductMediaType {
  IMAGE
  VIDEO
  THREE_SIXTY
  MANUAL_PDF
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum VariantStatus {
  ACTIVE
  INACTIVE
}

/// Kategori produk (socks, boxer, shorts, dsb.)
model ProductCategory {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  // Audit
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  // Soft delete
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deleteReason String?

  products Product[]

  @@map("product_categories")
}

/// Entitas produk utama — aggregate root katalog.
/// variantCount, priceFrom, priceTo, thumbnailUrl adalah denormalized fields
/// yang di-sync setiap kali varian diubah agar read path efisien tanpa JOIN.
model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  brand       String
  description String
  status      ProductStatus @default(DRAFT)
  categoryId  String

  // Denormalized untuk efisiensi read path (sync via application service)
  variantCount Int    @default(0)
  priceFrom    Float  @default(0)
  priceTo      Float  @default(0)
  thumbnailUrl String @default("")

  // Audit
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  // Soft delete
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deleteReason String?

  category       ProductCategory @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  variantOptions VariantOption[]
  seo            ProductSeo?

  // Pola akses: listing publik + admin queue
  @@index([status, categoryId, createdAt])
  @@map("products")
}

/// Unit jual nyata dengan SKU dan harga.
model ProductVariant {
  id             String        @id @default(cuid())
  productId      String
  sku            String        @unique
  price          Float
  compareAtPrice Float?
  variantLabel   String
  status         VariantStatus @default(ACTIVE)

  // Audit
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  // Soft delete
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deleteReason String?

  product       Product        @relation(fields: [productId], references: [id])
  variantValues VariantValue[]

  @@index([productId])
  @@map("product_variants")
}

/// Definisi dimensi varian pada level produk (mis. warna, ukuran, model).
model VariantOption {
  id           String @id @default(cuid())
  productId    String
  optionCode   String
  optionName   String
  displayOrder Int    @default(0)

  // Audit
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  product       Product        @relation(fields: [productId], references: [id])
  variantValues VariantValue[]

  @@index([productId])
  @@map("variant_options")
}

/// Media katalog — dapat dimiliki oleh Product atau Variant.
/// Mendukung IMAGE, VIDEO, THREE_SIXTY, MANUAL_PDF tanpa redesign entity.
model ProductMedia {
  id        String           @id @default(cuid())
  ownerType MediaOwnerType
  ownerId   String
  mediaType ProductMediaType @default(IMAGE)
  url       String
  altText   String           @default("")
  sortOrder Int              @default(0)

  // Audit
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  // Pola akses: semua media milik owner tertentu, diurutkan
  @@index([ownerType, ownerId, sortOrder])
  @@map("product_media")
}

/// Metadata SEO untuk halaman detail produk.
model ProductSeo {
  id              String  @id @default(cuid())
  productId       String  @unique
  metaTitle       String  @default("")
  metaDescription String  @default("")
  canonicalUrl    String  @default("")

  // Audit
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  product Product @relation(fields: [productId], references: [id])

  @@map("product_seo")
}

/// Nilai option yang dipakai oleh varian tertentu (mis. color=black, size=L).
model VariantValue {
  id         String @id @default(cuid())
  variantId  String
  optionId   String
  valueCode  String
  valueLabel String

  // Audit
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  variant ProductVariant @relation(fields: [variantId], references: [id])
  option  VariantOption  @relation(fields: [optionId], references: [id])

  @@index([variantId])
  @@map("variant_values")
}
